    "onboarding.vocab.subtitle": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wenn du dein Vokabular anonym teilst, hilfst du Spit, Namen, Marken und Fachbegriffe für alle besser zu erkennen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "By sharing your vocabulary anonymously, you help Spit better recognize names, brands, and technical terms for everyone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Al compartir tu vocabulario de forma anónima, ayudas a Spit a reconocer mejor nombres, marcas y términos técnicos para todos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "En partageant votre vocabulaire de manière anonyme, vous aidez Spit à mieux reconnaître les noms, marques et termes techniques pour tous."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Condividendo il tuo vocabolario in forma anonima, aiuti Spit a riconoscere meglio nomi, marchi e termini tecnici per tutti."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "語彙を匿名で共有すると、Spitが名前、ブランド名、専門用語をより正確に認識できるようになります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "어휘를 익명으로 공유하면 Spit이 이름, 브랜드, 전문 용어를 더 잘 인식하는 데 도움이 됩니다."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Ao compartilhar seu vocabulário de forma anônima, você ajuda o Spit a reconhecer melhor nomes, marcas e termos técnicos para todos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
