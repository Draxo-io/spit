    "Terms sent to Whisper as context — no automatic substitution. Use for product names that sound like common words (e.g. MEMSAGE sounds like \"mensagem\").": {
      "extractionState": "stale",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Begriffe an Whisper als Kontext — keine automatische Ersetzung. Für Produktnamen, die wie gewöhnliche Wörter klingen (z. B. MEMSAGE)."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Terms sent to Whisper as context — no automatic substitution. Use for product names that sound like common words."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Términos enviados a Whisper como contexto — sin sustitución automática. Para nombres de productos que suenan como palabras comunes (p. ej. MEMSAGE)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Termes envoyés à Whisper comme contexte — sans substitution automatique. Pour les noms de produits qui ressemblent à des mots courants (ex. MEMSAGE)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Termini inviati a Whisper come contesto — nessuna sostituzione automatica. Per nomi di prodotti che suonano come parole comuni (es. MEMSAGE)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Whisperにコンテキストとして送信するキーワード — 自動置換なし。一般的な単語に聞こえる製品名に使います（例: MEMSAGE）。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Whisper에 컨텍스트로 전송되는 용어 — 자동 대체 없음. 일반적인 단어처럼 들리는 제품명에 사용하세요（예: MEMSAGE）."
          }
        },
        "pt": {
          "stringUnit": {
            "state": "translated",
            "value": "Termos enviados ao Whisper como contexto — sem substituição automática. Útil para nomes de produtos que soam como palavras comuns (ex: MEMSAGE soa como \"mensagem\")."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Termos enviados ao Whisper como contexto — sem substituição automática. Útil para nomes de produtos que soam como palavras comuns (ex: MEMSAGE soa como \"mensagem\")."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "作为上下文发送给 Whisper 的词汇 — 无自动替换。用于听起来像普通词汇的产品名称（例如 MEMSAGE）。"
          }
        }
      }
    },
